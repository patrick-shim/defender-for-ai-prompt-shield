AZURE_OPENAI_ENDPOINT=youraiendpoint
OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=your_model
AZURE_CONTENT_SAFETY_ENDPOINT=azure_content_safety_endpoint

# Content Safety configuration
CONTENT_SEVERITY_THRESHOLD=5  # Block content with severity >= 5 (0-7 scale)

# Logging configuration
VERBOSE_LOGGING=false  # Set to true to see detailed JSON logs, false for clean output

# SecurityContext configuration (for demo purposes)
TENANT_ID=your-tenant-id
USER_ID=your-user@domain.com
USER_ROLES=AI-Sec,GBB
AUTH_STRENGTH=MFA
DATA_CLASSIFICATION=Internal
