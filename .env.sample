AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_DEFAULT=gpt-5-default
AZURE_OPENAI_DEPLOYMENT_PERMISSIVE=gpt-5-permissive
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-content-safety>.cognitiveservices.azure.com/

AZURE_MAX_TOKENS=512
AZURE_TEMPERATURE=1

ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# Batch input configuration
INPUT_PROMPTS_BATCH=input_prompts.json

# Content Safety configuration
CONTENT_SEVERITY_THRESHOLD=5  # Block content with severity >= 5 (0-7 scale)

# Logging configuration
VERBOSE_LOGGING=false  # Set to true to see detailed JSON logs, false for clean output

# SecurityContext configuration (for demo purposes)
TENANT_ID=your-tenant-id
USER_ID=your-user@domain.com
USER_ROLES=AI-Sec,GBB
AUTH_STRENGTH=MFA
DATA_CLASSIFICATION=Internal
